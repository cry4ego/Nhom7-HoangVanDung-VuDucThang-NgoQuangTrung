<odoo>
    <!-- Tree View — [F4] Thêm cột cảm xúc -->
    <record id="view_feedback_tree" model="ir.ui.view">
        <field name="name">khach_hang.feedback.tree</field>
        <field name="model">khach_hang.feedback</field>
        <field name="arch" type="xml">
            <tree decoration-success="sentiment == 'positive'"
                  decoration-warning="sentiment == 'neutral'"
                  decoration-danger="sentiment == 'negative'">
                <field name="customer_id"/>
                <field name="question"/>
                <field name="supporter"/>
                <field name="sentiment" optional="show"/>
                <field name="sentiment_score" optional="show" string="Điểm CX"/>
                <field name="answer"/>
            </tree>
        </field>
    </record>

    <!-- Form View — [F4] Thêm nhóm AI Analysis -->
    <record id="view_feedback_form" model="ir.ui.view">
        <field name="name">khach_hang.feedback.form</field>
        <field name="model">khach_hang.feedback</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Thông tin phản hồi">
                        <field name="customer_id"/>
                        <field name="question"/>
                        <field name="supporter"/>
                        <field name="answer"/>
                    </group>
                    <!-- [F4] AI Sentiment Analysis Block -->
                    <group string="🤖 Phân tích cảm xúc (AI)" attrs="{'invisible': [('sentiment', '=', False)]}">
                        <field name="sentiment" readonly="1"/>
                        <field name="sentiment_score" readonly="1" widget="float"/>
                        <field name="sentiment_reason" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_feedback_list" model="ir.actions.act_window">
        <field name="name">Phản Hồi</field>
        <field name="res_model">khach_hang.feedback</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_feedback_list" name="Phản Hồi" parent="menu_customer_root" action="action_feedback_list" sequence="50"/>
</odoo>