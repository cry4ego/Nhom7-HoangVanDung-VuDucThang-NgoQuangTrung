<odoo>
    <!-- Tree View -->
    <record id="view_customer_tree" model="ir.ui.view">
        <field name="name">khach_hang.customer.tree</field>
        <field name="model">khach_hang.customer</field>
        <field name="arch" type="xml">
            <tree decoration-danger="churn_risk_label == 'high'"
                  decoration-warning="churn_risk_label == 'medium'">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="nhan_vien_phu_trach_id"/>
                <field name="order_count"/>
                <field name="churn_risk_label" optional="show" string="Rủi ro"/>
                <field name="churn_risk_score" optional="show" string="Score (%)"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_customer_form" model="ir.ui.view">
        <field name="name">khach_hang.customer.form</field>
        <field name="model">khach_hang.customer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- [F5] Nút tính churn risk thủ công -->
                    <button name="action_compute_churn_risk" string="🔄 Tính Churn Risk" type="object"
                            class="oe_highlight" icon="fa-refresh"/>
                </header>
                <sheet>
                    <group>
                        <group string="Thông tin cơ bản">
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="address"/>
                            <field name="nhan_vien_phu_trach_id"/>
                        </group>
                        <group string="Đăng nhập">
                            <field name="username"/>
                            <field name="password_hash" invisible="1"/>
                        </group>
                    </group>
                    <!-- [F5] AI Churn Risk Block -->
                    <group string="🤖 Phân tích rủi ro rời bỏ (AI)">
                        <field name="churn_risk_label" readonly="1"/>
                        <field name="churn_risk_score" readonly="1" string="Điểm rủi ro (%)"/>
                        <field name="churn_reason" readonly="1" string="Lý do"/>
                        <field name="churn_last_computed" readonly="1" string="Tính lần cuối"/>
                    </group>
                    <notebook>
                        <page string="Đơn Hàng">
                            <field name="order_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="date_order"/>
                                    <field name="total_amount"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Phản Hồi">
                            <field name="feedback_ids">
                                <tree>
                                    <field name="question"/>
                                    <field name="sentiment"/>
                                    <field name="sentiment_score"/>
                                    <field name="answer"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Hoạt Động Chăm Sóc">
                            <field name="care_activity_ids">
                                <tree>
                                    <field name="care_date"/>
                                    <field name="contact_method"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_customer_graph" model="ir.ui.view">
        <field name="name">khach_hang.customer.graph</field>
        <field name="model">khach_hang.customer</field>
        <field name="arch" type="xml">
            <graph string="Số Đơn Hàng Theo Khách Hàng" type="bar">
                <field name="name" type="row"/>
                <field name="order_count" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Actions and Menu -->
    <record id="action_customer_list" model="ir.actions.act_window">
        <field name="name">Khách Hàng</field>
        <field name="res_model">khach_hang.customer</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_customer_graph" model="ir.actions.act_window">
        <field name="name">Biểu Đồ Số Đơn Hàng</field>
        <field name="res_model">khach_hang.customer</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_customer_graph"/>
    </record>

    <menuitem id="menu_customer_root" name="Quản Lý Khách Hàng" sequence="10"/>
    <menuitem id="menu_customer_list" name="Khách Hàng" parent="menu_customer_root" action="action_customer_list" sequence="10"/>
    <menuitem id="menu_customer_graph" name="Biểu Đồ Đơn Hàng" parent="menu_customer_root" action="action_customer_graph" sequence="20"/>
</odoo>